## ─── Copy this file to .env and fill in your real values ──────────────────────
## NEVER commit .env — only .env.example is safe to commit.

## ─── MongoDB Atlas ─────────────────────────────────────────────────────────────
## https://cloud.mongodb.com → Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/redlinesmp?retryWrites=true&w=majority

## ─── JWT Secret ────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string

## ─── Server Port ───────────────────────────────────────────────────────────────
PORT=5000

## ─── One-time Admin Setup Key ──────────────────────────────────────────────────
ADMIN_SETUP_KEY=your-admin-setup-key-here

## ─── Payment Provider Switch ──────────────────────────────────────────────────────────
## Set to "razorpay" or "cashfree" to choose active payment gateway
PAYMENT_PROVIDER=cashfree

## ─── Razorpay ──────────────────────────────────────────────────────────────────────────────
## Test keys: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=

## ─── Cashfree ──────────────────────────────────────────────────────────────────────────────
## https://merchant.cashfree.com → Developers → API Keys
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_WEBHOOK_SECRET=
## SANDBOX or PRODUCTION
CASHFREE_ENV=SANDBOX

## ─── Frontend URL (for CORS in production) ───────────────────────────────────
## Your Vercel deployment URL, e.g. https://redlinesmp.vercel.app
FRONTEND_URL=https://your-app.vercel.app

## ─── RCON (Minecraft Server) ───────────────────────────────────────────────────
RCON_HOST=
RCON_PORT=25575
RCON_PASSWORD=

## ─── Discord OAuth (Creator login) ───────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=

## ─── Discord OAuth (Admin login - allowlisted) ───────────────────────────────
## You can reuse DISCORD_CLIENT_ID/SECRET above, but callback URI must match /api/admin/auth/discord/callback
DISCORD_ADMIN_CLIENT_ID=
DISCORD_ADMIN_CLIENT_SECRET=
DISCORD_ADMIN_REDIRECT_URI=

## Comma-separated Discord user IDs allowed to sign in as admin via OAuth
DISCORD_ADMIN_IDS=

## Admin bootstrap uses discordId directly (POST /api/admin/setup)
